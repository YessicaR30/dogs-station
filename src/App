import React, { useState, useEffect, useMemo } from "react";

// ---- CONFIG ----------------------------------------------------------
// Default WhatsApp number — editable anytime from Staff > Settings, no code changes needed.
const DEFAULT_WHATSAPP_NUMBER = "61416379260"; // country code + number, no + or spaces
// TODO: change this to whatever code you want staff to use to open the order list.
const STAFF_PIN = "1974";
// TODO: paste your Google Apps Script Web App URL here once deployed (see setup guide provided separately).
const SHEET_WEBHOOK_URL = "https://script.google.com/macros/s/AKfycbzkxHFUZx3i8U-2Weg57ouiVr7fngOsvKlztEFl1wbD_33FG_G8HxC3t9Mk2LJq8MSCwQ/exec";

// Official logo, extracted from the Dog's Station menu.
const LOGO_URL = "data:image/png;base64,";

const DAY_NAMES = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];

// ---- BACKEND API HELPERS ------------------------------------------------
// Everything (orders, schedule, settings) is read from and written to the
// Google Sheet through the Apps Script Web App at SHEET_WEBHOOK_URL.
// This makes the app work the same way whether it's opened inside Claude
// or hosted on your own domain.

async function apiGet(action) {
  if (!SHEET_WEBHOOK_URL) throw new Error("No backend URL configured");
  const res = await fetch(`${SHEET_WEBHOOK_URL}?action=${action}`);
  const data = await res.json();
  if (data.result !== "success") throw new Error(data.message || "Request failed");
  return data;
}

async function apiPost(payload) {
  if (!SHEET_WEBHOOK_URL) throw new Error("No backend URL configured");
  const res = await fetch(SHEET_WEBHOOK_URL, {
    method: "POST",
    headers: { "Content-Type": "text/plain;charset=utf-8" },
    body: JSON.stringify(payload),
  });
  const data = await res.json();
  if (data.result !== "success") throw new Error(data.message || "Request failed");
  return data;
}

// Starting schedule — editable later from the Staff > Schedule tab.
const DEFAULT_SLOTS = [
  { id: "slot-thu", dayOfWeek: 4, location: "Sunshine", time: "6:00 PM", active: true },
  { id: "slot-fri", dayOfWeek: 5, location: "Fitzroy", time: "6:00 PM", active: true },
  { id: "slot-sat-1", dayOfWeek: 6, location: "Footscray", time: "12:00 PM", active: true },
  { id: "slot-sat-2", dayOfWeek: 6, location: "Essendon", time: "6:00 PM", active: true },
];

const PRODUCTS = [
  { id: "special", name: "Special Hot Dog", price: 22 },
  { id: "double", name: "Double Special Hot Dog", price: 24 },
];

const DRINKS = [
  { id: "coke-classic", name: "Coca Cola Classic 375ml (Can)", price: 3 },
  { id: "sprite-lemonade", name: "Sprite Lemonade 375ml (Can)", price: 3 },
  { id: "solo", name: "Solo 375ml (Can)", price: 3 },
];

const ALL_PRODUCTS = [...PRODUCTS, ...DRINKS];

function findProduct(id) {
  return ALL_PRODUCTS.find((p) => p.id === id);
}

function isHotDog(id) {
  return PRODUCTS.some((p) => p.id === id);
}

const TOPPINGS = [
  { id: "pineapple-sauce", name: "Special Pineapple Sauce", price: 2 },
  { id: "pink-sauce", name: "Special Pink Sauce", price: 2 },
  { id: "ketchup", name: "Ketchup", price: 1.8 },
  { id: "mayo", name: "Mayonnaise", price: 1.8 },
  { id: "mustard", name: "Mustard", price: 1.8 },
  { id: "pineapple-pieces", name: "Pineapple Pieces", price: 2.5 },
  { id: "quail-eggs", name: "Quail Eggs (3 units)", price: 4 },
  { id: "onion", name: "Onion", price: 0 },
];

const STEPS = ["Day", "Food", "Extras", "Confirm"];

// ---- HELPERS -----------------------------------------------------------
function nextUpcomingDates(slots, closedDates) {
  // Returns the next available pickup dates (must be at least tomorrow).
  const results = [];
  const now = new Date();
  const tomorrow = new Date(now);
  tomorrow.setDate(tomorrow.getDate() + 1);
  tomorrow.setHours(0, 0, 0, 0);
  const activeSlots = (slots || []).filter((s) => s.active !== false);

  for (let i = 0; i < 28 && results.length < 6; i++) {
    const d = new Date(tomorrow);
    d.setDate(tomorrow.getDate() + i);
    const dow = d.getDay(); // 0 Sun ... 6 Sat
    const dateKey = d.toISOString().slice(0, 10);
    if ((closedDates || []).includes(dateKey)) continue;
    const matches = activeSlots.filter((s) => s.dayOfWeek === dow);
    matches.forEach((s) => {
      results.push({ ...s, dayName: DAY_NAMES[s.dayOfWeek], date: new Date(d) });
    });
  }
  return results;
}

function formatDate(d) {
  return d.toLocaleDateString("en-AU", { weekday: "short", day: "numeric", month: "short" });
}

function formatGroupDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString("en-AU", { weekday: "long", day: "numeric", month: "short", year: "numeric" });
}

function money(n) {
  return `$${n.toFixed(2)}`;
}

// ---- MAIN COMPONENT -----------------------------------------------------
export default function DogsStationOrder() {
  const [view, setView] = useState("order"); // "order" | "staff"
  const [staffTab, setStaffTab] = useState("orders"); // "orders" | "schedule" | "settings"
  const [staffUnlocked, setStaffUnlocked] = useState(false);
  const [pinInput, setPinInput] = useState("");
  const [pinError, setPinError] = useState("");
  const [orders, setOrders] = useState([]);
  const [ordersLoading, setOrdersLoading] = useState(false);
  const [ordersError, setOrdersError] = useState("");

  const [scheduleSlots, setScheduleSlots] = useState(DEFAULT_SLOTS);
  const [closedDates, setClosedDates] = useState([]);
  const [newClosedDate, setNewClosedDate] = useState("");
  const [scheduleSaving, setScheduleSaving] = useState(false);
  const [scheduleSaveMsg, setScheduleSaveMsg] = useState("");

  const [whatsappNumber, setWhatsappNumber] = useState(DEFAULT_WHATSAPP_NUMBER);
  const [whatsappInput, setWhatsappInput] = useState(DEFAULT_WHATSAPP_NUMBER);
  const [settingsSaving, setSettingsSaving] = useState(false);
  const [settingsSaveMsg, setSettingsSaveMsg] = useState("");

  const [step, setStep] = useState(0);
  const [slot, setSlot] = useState(null);
  const [cartItems, setCartItems] = useState([]);
  const [customerName, setCustomerName] = useState("");
  const [customerEmail, setCustomerEmail] = useState("");
  const [customerPhone, setCustomerPhone] = useState("");
  const [notes, setNotes] = useState("");
  const [submitting, setSubmitting] = useState(false);
  const [submitted, setSubmitted] = useState(false);
  const [orderId, setOrderId] = useState(null);
  const [saveIssue, setSaveIssue] = useState(false);
  const [error, setError] = useState("");

  const upcoming = useMemo(
    () => nextUpcomingDates(scheduleSlots, closedDates),
    [scheduleSlots, closedDates]
  );

  const groupedOrders = useMemo(() => {
    const groups = {};
    orders.forEach((o) => {
      const key = `${o.pickupDate}|${o.location}|${o.pickupTime}`;
      if (!groups[key]) {
        groups[key] = {
          key,
          pickupDate: o.pickupDate,
          day: o.day,
          location: o.location,
          pickupTime: o.pickupTime,
          orders: [],
        };
      }
      groups[key].orders.push(o);
    });
    return Object.values(groups).sort(
      (a, b) => new Date(a.pickupDate) - new Date(b.pickupDate)
    );
  }, [orders]);

  useEffect(() => {
    const link = document.createElement("style");
    link.innerHTML = `@import url('https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;500;600;700&display=swap');`;
    document.head.appendChild(link);
    return () => document.head.removeChild(link);
  }, []);

  useEffect(() => {
    loadSchedule();
    loadSettings();
  }, []);

  async function loadSettings() {
    try {
      const res = await apiGet("settings");
      if (res.data && res.data.whatsappNumber) {
        setWhatsappNumber(res.data.whatsappNumber);
        setWhatsappInput(res.data.whatsappNumber);
      }
    } catch (e) {
      // no saved settings yet — keep defaults
    }
  }

  async function saveSettings() {
    setSettingsSaving(true);
    setSettingsSaveMsg("");
    try {
      const cleaned = whatsappInput.replace(/[^\d]/g, "");
      await apiPost({ action: "saveSettings", whatsappNumber: cleaned });
      setWhatsappNumber(cleaned);
      setWhatsappInput(cleaned);
      setSettingsSaveMsg("Saved ✓");
      setTimeout(() => setSettingsSaveMsg(""), 2500);
    } catch (e) {
      setSettingsSaveMsg("Couldn't save. Try again.");
    } finally {
      setSettingsSaving(false);
    }
  }

  async function loadSchedule() {
    try {
      const res = await apiGet("schedule");
      if (res.data) {
        if (res.data.slots && res.data.slots.length) setScheduleSlots(res.data.slots);
        if (res.data.closedDates) setClosedDates(res.data.closedDates);
      }
    } catch (e) {
      // no saved schedule yet — keep defaults
    }
  }

  async function saveScheduleChanges() {
    setScheduleSaving(true);
    setScheduleSaveMsg("");
    try {
      await apiPost({ action: "saveSchedule", slots: scheduleSlots, closedDates });
      setScheduleSaveMsg("Saved ✓");
      setTimeout(() => setScheduleSaveMsg(""), 2500);
    } catch (e) {
      setScheduleSaveMsg("Couldn't save. Try again.");
    } finally {
      setScheduleSaving(false);
    }
  }

  function updateSlot(id, field, value) {
    setScheduleSlots((prev) => prev.map((s) => (s.id === id ? { ...s, [field]: value } : s)));
  }

  function addSlot() {
    setScheduleSlots((prev) => [
      ...prev,
      { id: `slot-${Date.now()}`, dayOfWeek: 4, location: "", time: "6:00 PM", active: true },
    ]);
  }

  function removeSlot(id) {
    setScheduleSlots((prev) => prev.filter((s) => s.id !== id));
  }

  function addClosedDate() {
    if (!newClosedDate) return;
    setClosedDates((prev) => (prev.includes(newClosedDate) ? prev : [...prev, newClosedDate].sort()));
    setNewClosedDate("");
  }

  function removeClosedDate(d) {
    setClosedDates((prev) => prev.filter((x) => x !== d));
  }

  function itemToppingsTotal(item) {
    return TOPPINGS.reduce((sum, t) => sum + (item.toppings[t.id] || 0) * t.price, 0);
  }

  const itemsTotal = cartItems.reduce((sum, item) => {
    const product = findProduct(item.productId);
    return sum + (product ? product.price : 0);
  }, 0);
  const toppingsTotal = cartItems.reduce((sum, item) => sum + itemToppingsTotal(item), 0);
  const total = itemsTotal + toppingsTotal;
  const itemCount = cartItems.length;

  const canProceed = [
    !!slot,
    cartItems.length > 0,
    true,
    customerName.trim().length > 0 &&
      customerEmail.trim().includes("@") &&
      customerPhone.trim().length > 0,
  ][step];

  function addCartItem(productId) {
    setCartItems((prev) => [
      ...prev,
      { id: `item-${Date.now()}-${Math.random().toString(36).slice(2, 6)}`, productId, toppings: {} },
    ]);
  }

  function removeCartItem(id) {
    setCartItems((prev) => prev.filter((item) => item.id !== id));
  }

  function changeItemToppingQty(itemId, toppingId, delta) {
    setCartItems((prev) =>
      prev.map((item) => {
        if (item.id !== itemId) return item;
        const current = item.toppings[toppingId] || 0;
        const next = Math.max(0, current + delta);
        return { ...item, toppings: { ...item.toppings, [toppingId]: next } };
      })
    );
  }

  async function submitOrder() {
    setSubmitting(true);
    setError("");
    try {
      const id = `${Date.now()}-${Math.random().toString(36).slice(2, 7)}`;
      const order = {
        id,
        customerName: customerName.trim(),
        customerEmail: customerEmail.trim(),
        customerPhone: customerPhone.trim(),
        day: slot.dayName,
        location: slot.location,
        pickupTime: slot.time,
        pickupDate: slot.date.toISOString(),
        items: cartItems.map((item) => {
          const product = findProduct(item.productId);
          return {
            name: product.name,
            price: product.price,
            toppings: TOPPINGS.filter((t) => item.toppings[t.id] > 0).map((t) => ({
              name: t.name,
              qty: item.toppings[t.id],
              price: t.price,
            })),
          };
        }),
        notes: notes.trim(),
        total,
        createdAt: new Date().toISOString(),
        status: "pending_payment",
      };
      let saveWarning = false;
      try {
        await apiPost({ action: "createOrder", order });
      } catch (apiErr) {
        // Don't block the customer's order confirmation if the sheet sync
        // fails — they still get confirmed and told to send their receipt.
        saveWarning = true;
      }
      setOrderId(id);
      setSaveIssue(saveWarning);
      setSubmitted(true);
    } catch (e) {
      setError("Something went wrong preparing your order. Please try again.");
    } finally {
      setSubmitting(false);
    }
  }

  async function loadOrders() {
    setOrdersLoading(true);
    setOrdersError("");
    try {
      const res = await apiGet("orders");
      const loaded = (res.orders || []).sort(
        (a, b) => new Date(a.pickupDate) - new Date(b.pickupDate)
      );
      setOrders(loaded);
    } catch (e) {
      setOrdersError("Couldn't load orders. Try refreshing.");
    } finally {
      setOrdersLoading(false);
    }
  }

  async function markStatus(order, status) {
    try {
      await apiPost({ action: "updateOrderStatus", id: order.id, status });
      setOrders((prev) => prev.map((o) => (o.id === order.id ? { ...o, status } : o)));
    } catch (e) {
      setOrdersError("Couldn't update that order. Try again.");
    }
  }

  function checkPin() {
    if (pinInput === STAFF_PIN) {
      setStaffUnlocked(true);
      setPinError("");
      loadOrders();
    } else {
      setPinError("Wrong code, try again.");
    }
  }

  function resetOrder() {
    setStep(0);
    setSlot(null);
    setCartItems([]);
    setNotes("");
    setCustomerName("");
    setCustomerEmail("");
    setCustomerPhone("");
    setSubmitted(false);
    setOrderId(null);
    setSaveIssue(false);
  }

  const waMessage = slot
    ? encodeURIComponent(
        `Hi Dog's Station! Order confirmation.\nName: ${customerName}\nEmail: ${customerEmail}\nPhone: ${customerPhone}\nPickup: ${slot.dayName} (${slot.location}) at ${slot.time}\n${cartItems
          .map((item, idx) => {
            const product = findProduct(item.productId);
            const tops = TOPPINGS.filter((t) => item.toppings[t.id] > 0)
              .map((t) => (item.toppings[t.id] > 1 ? `${item.toppings[t.id]}x ${t.name}` : t.name))
              .join(", ");
            return `${idx + 1}. ${product.name}${tops ? " - " + tops : ""}`;
          })
          .join(
            "\n"
          )}${notes.trim() ? `\nNote: ${notes.trim()}` : ""}\nTotal: ${money(total)}\n(Receipt attached)`
      )
    : "";
  const waLink = whatsappNumber
    ? `https://wa.me/${whatsappNumber}?text=${waMessage}`
    : null;

  return (
    <div style={styles.page}>
      <style>{`
        * { box-sizing: border-box; }
        button { font-family: inherit; cursor: pointer; }
        input { font-family: inherit; }
      `}</style>

      <div style={styles.shell}>
        {/* Header */}
        <div style={styles.header}>
          <img src={LOGO_URL} alt="Dog's Station" style={styles.logoImg} />
          <div style={{ flex: 1 }}>
            <div style={styles.tagline}>Order ahead pop-up</div>
          </div>
          <button
            style={styles.staffLink}
            onClick={() => setView(view === "order" ? "staff" : "order")}
          >
            {view === "order" ? "Staff" : "← Orders"}
          </button>
        </div>

        {view === "staff" ? (
          !staffUnlocked ? (
            <div style={styles.pinScreen}>
              <h2 style={styles.h2}>Staff access</h2>
              <p style={styles.helper}>Enter the code to see incoming orders.</p>
              <input
                type="password"
                inputMode="numeric"
                value={pinInput}
                onChange={(e) => setPinInput(e.target.value)}
                onKeyDown={(e) => e.key === "Enter" && checkPin()}
                style={styles.input}
                placeholder="Code"
              />
              {pinError && <div style={styles.errorText}>{pinError}</div>}
              <button style={styles.nextBtnStatic} onClick={checkPin}>
                Unlock
              </button>
            </div>
          ) : (
            <div style={styles.content}>
              <div style={styles.staffTabs}>
                <button
                  style={{
                    ...styles.staffTabBtn,
                    ...(staffTab === "orders" ? styles.staffTabBtnActive : {}),
                  }}
                  onClick={() => setStaffTab("orders")}
                >
                  Orders
                </button>
                <button
                  style={{
                    ...styles.staffTabBtn,
                    ...(staffTab === "schedule" ? styles.staffTabBtnActive : {}),
                  }}
                  onClick={() => setStaffTab("schedule")}
                >
                  Schedule
                </button>
                <button
                  style={{
                    ...styles.staffTabBtn,
                    ...(staffTab === "settings" ? styles.staffTabBtnActive : {}),
                  }}
                  onClick={() => setStaffTab("settings")}
                >
                  Settings
                </button>
              </div>

              {staffTab === "orders" ? (
                <>
                <div style={styles.staffHeaderRow}>
                <h2 style={styles.h2}>Incoming orders</h2>
                <button style={styles.refreshBtn} onClick={loadOrders} disabled={ordersLoading}>
                  {ordersLoading ? "…" : "Refresh"}
                </button>
              </div>
              {ordersError && <div style={styles.errorText}>{ordersError}</div>}
              {!ordersLoading && orders.length === 0 && (
                <p style={styles.helper}>No orders yet.</p>
              )}
              <div style={styles.groupList}>
                {groupedOrders.map((group) => {
                  const groupHotDogs = group.orders.reduce((sum, o) => sum + o.items.length, 0);
                  const groupRevenue = group.orders.reduce((sum, o) => sum + o.total, 0);
                  return (
                    <div key={group.key} style={styles.groupBlock}>
                      <div style={styles.groupHeader}>
                        <div>
                          <div style={styles.groupDate}>{formatGroupDate(group.pickupDate)}</div>
                          <div style={styles.groupSlot}>{group.location} · {group.pickupTime}</div>
                        </div>
                        <div style={styles.groupStats}>
                          <div>{group.orders.length} order{group.orders.length !== 1 ? "s" : ""}</div>
                          <div>{groupHotDogs} hot dog{groupHotDogs !== 1 ? "s" : ""}</div>
                          <div style={{ fontWeight: 700 }}>{money(groupRevenue)}</div>
                        </div>
                      </div>
                      <div style={styles.orderList}>
                        {group.orders.map((o) => (
                          <div key={o.id} style={styles.orderCard}>
                            <div style={styles.orderCardTop}>
                              <div>
                                <div style={styles.orderName}>{o.customerName}</div>
                                {(o.customerEmail || o.customerPhone) && (
                                  <div style={styles.orderContact}>
                                    {o.customerEmail}{o.customerEmail && o.customerPhone ? " · " : ""}{o.customerPhone}
                                  </div>
                                )}
                              </div>
                              <div
                                style={{
                                  ...styles.statusBadge,
                                  background: o.status === "confirmed" ? "#FFCC00" : "#E5B234",
                                }}
                              >
                                {o.status === "confirmed" ? "Paid" : "Awaiting"}
                              </div>
                            </div>
                            <div style={styles.divider} />
                            {o.items.map((it, i) => (
                              <div key={i} style={{ marginBottom: it.toppings && it.toppings.length ? 6 : 0 }}>
                                <div style={styles.reviewLine}>
                                  {i + 1}. {it.name}
                                </div>
                                {it.toppings && it.toppings.length > 0 && (
                                  <div style={{ ...styles.reviewLine, color: "#8A6D00", paddingLeft: 12, fontSize: 12 }}>
                                    + {it.toppings.map((t) => (t.qty > 1 ? `${t.qty}x ${t.name}` : t.name)).join(", ")}
                                  </div>
                                )}
                              </div>
                            ))}
                            {o.notes && (
                              <div style={styles.noteFlag}>⚠ {o.notes}</div>
                            )}
                            <div style={styles.divider} />
                            <div style={{ ...styles.reviewLine, fontWeight: 700 }}>
                              Total {money(o.total)}
                            </div>
                            {o.status !== "confirmed" && (
                              <button style={styles.confirmBtn} onClick={() => markStatus(o, "confirmed")}>
                                Mark as paid
                              </button>
                            )}
                          </div>
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
                </>
              ) : staffTab === "schedule" ? (
                <>
                  <h2 style={styles.h2}>Store schedule</h2>
                  <p style={styles.helper}>
                    Add, edit, or turn off pickup slots. Customers only ever see active slots.
                  </p>
                  <div style={styles.scheduleList}>
                    {scheduleSlots.map((s) => (
                      <div key={s.id} style={styles.scheduleCard}>
                        <div style={styles.scheduleRow}>
                          <select
                            value={s.dayOfWeek}
                            onChange={(e) => updateSlot(s.id, "dayOfWeek", Number(e.target.value))}
                            style={styles.scheduleSelect}
                          >
                            {DAY_NAMES.map((d, i) => (
                              <option key={i} value={i}>{d}</option>
                            ))}
                          </select>
                          <button
                            style={{
                              ...styles.toggleBtn,
                              background: s.active !== false ? "#FFCC00" : "#B8AD91",
                              color: s.active !== false ? "#2B2B2B" : "#fff",
                            }}
                            onClick={() => updateSlot(s.id, "active", s.active === false)}
                          >
                            {s.active !== false ? "Open" : "Closed"}
                          </button>
                        </div>
                        <input
                          value={s.location}
                          onChange={(e) => updateSlot(s.id, "location", e.target.value)}
                          placeholder="Location"
                          style={styles.input}
                        />
                        <input
                          value={s.time}
                          onChange={(e) => updateSlot(s.id, "time", e.target.value)}
                          placeholder="Time e.g. 6:00 PM"
                          style={styles.input}
                        />
                        <button style={styles.deleteBtn} onClick={() => removeSlot(s.id)}>
                          Remove slot
                        </button>
                      </div>
                    ))}
                  </div>
                  <button style={styles.addSlotBtn} onClick={addSlot}>
                    + Add pickup slot
                  </button>

                  <h2 style={{ ...styles.h2, marginTop: 24 }}>Closed dates</h2>
                  <p style={styles.helper}>Block off a specific date (holidays, etc.) even if it falls on a normally open day.</p>
                  <div style={styles.closedDateAddRow}>
                    <input
                      type="date"
                      value={newClosedDate}
                      onChange={(e) => setNewClosedDate(e.target.value)}
                      style={{ ...styles.input, marginBottom: 0, flex: 1 }}
                    />
                    <button style={styles.refreshBtn} onClick={addClosedDate}>Add</button>
                  </div>
                  {closedDates.length > 0 && (
                    <div style={styles.closedDateList}>
                      {closedDates.map((d) => (
                        <div key={d} style={styles.closedDateRow}>
                          <span>{d}</span>
                          <button style={styles.deleteBtnSmall} onClick={() => removeClosedDate(d)}>Remove</button>
                        </div>
                      ))}
                    </div>
                  )}

                  <button
                    style={{ ...styles.nextBtnStatic, marginTop: 20 }}
                    onClick={saveScheduleChanges}
                    disabled={scheduleSaving}
                  >
                    {scheduleSaving ? "Saving…" : "Save schedule"}
                  </button>
                  {scheduleSaveMsg && <div style={styles.scheduleSaveMsg}>{scheduleSaveMsg}</div>}
                </>
              ) : (
                <>
                  <h2 style={styles.h2}>Settings</h2>
                  <p style={styles.helper}>
                    Edit anytime — changes apply immediately, no code needed.
                  </p>
                  <div style={styles.notesLabel}>WhatsApp number for receipts</div>
                  <input
                    type="tel"
                    value={whatsappInput}
                    onChange={(e) => setWhatsappInput(e.target.value)}
                    placeholder="e.g. 61416379260"
                    style={styles.input}
                  />
                  <p style={{ ...styles.helper, marginTop: -8 }}>
                    Country code + number, no + or spaces (we'll clean it up automatically).
                  </p>
                  <button
                    style={styles.nextBtnStatic}
                    onClick={saveSettings}
                    disabled={settingsSaving}
                  >
                    {settingsSaving ? "Saving…" : "Save settings"}
                  </button>
                  {settingsSaveMsg && <div style={styles.scheduleSaveMsg}>{settingsSaveMsg}</div>}
                </>
              )}
            </div>
          )
        ) : !submitted ? (
          <>
            {/* Step indicator */}
            <div style={styles.stepsRow}>
              {STEPS.map((s, i) => (
                <div key={s} style={styles.stepItem}>
                  <div
                    style={{
                      ...styles.stepDot,
                      background: i < step ? "#FFCC00" : i === step ? "#FF3131" : "#EAE0CB",
                      color: i < step ? "#2B2B2B" : i === step ? "#FBF3E4" : "#9C8F72",
                    }}
                  >
                    {i < step ? "✓" : i + 1}
                  </div>
                  <div style={{ ...styles.stepLabel, color: i === step ? "#221F1F" : "#9C8F72" }}>{s}</div>
                </div>
              ))}
            </div>

            {/* Content */}
            <div style={styles.content}>
              {step === 0 && (
                <div>
                  <h2 style={styles.h2}>When do you want to pick up?</h2>
                  <p style={styles.helper}>Orders must be placed at least one day ahead — same-day pickup isn't available.</p>
                  <div style={styles.slotList}>
                    {upcoming.length === 0 && (
                      <p style={styles.helper}>No pickup dates available right now — check back soon.</p>
                    )}
                    {upcoming.map((s, idx) => (
                      <button
                        key={idx}
                        onClick={() => setSlot(s)}
                        style={{
                          ...styles.slotCard,
                          borderColor: slot && slot.id === s.id && slot.date.getTime() === s.date.getTime() ? "#FF3131" : "#EAE0CB",
                          background: slot && slot.id === s.id && slot.date.getTime() === s.date.getTime() ? "#FDEDE7" : "#FFFFFF",
                        }}
                      >
                        <div style={styles.slotDate}>{formatDate(s.date)}</div>
                        <div style={styles.slotDetail}>{s.location} · {s.time}</div>
                      </button>
                    ))}
                  </div>
                </div>
              )}

              {step === 1 && (
                <div>
                  <h2 style={styles.h2}>Pick your hot dogs & drinks</h2>
                  <p style={styles.helper}>Tap "Add" for each item you want — you'll customize each hot dog's extras next.</p>
                  <div style={styles.productList}>
                    {PRODUCTS.map((p) => (
                      <div key={p.id} style={styles.productRow}>
                        <div>
                          <div style={styles.productName}>{p.name}</div>
                          <div style={styles.productPrice}>{money(p.price)}</div>
                        </div>
                        <button style={styles.addItemBtn} onClick={() => addCartItem(p.id)}>
                          + Add
                        </button>
                      </div>
                    ))}
                  </div>

                  <div style={{ ...styles.notesLabel, marginTop: 20, marginBottom: 8 }}>Drinks</div>
                  <div style={styles.productList}>
                    {DRINKS.map((d) => (
                      <div key={d.id} style={styles.productRow}>
                        <div>
                          <div style={styles.productName}>{d.name}</div>
                          <div style={styles.productPrice}>{money(d.price)}</div>
                        </div>
                        <button style={styles.addItemBtn} onClick={() => addCartItem(d.id)}>
                          + Add
                        </button>
                      </div>
                    ))}
                  </div>

                  {cartItems.length > 0 && (
                    <div style={styles.cartSection}>
                      <div style={styles.notesLabel}>Your order ({cartItems.length})</div>
                      <div style={styles.cartList}>
                        {cartItems.map((item, idx) => {
                          const product = findProduct(item.productId);
                          return (
                            <div key={item.id} style={styles.cartLineRow}>
                              <span>{idx + 1}. {product.name}</span>
                              <button style={styles.removeLineBtn} onClick={() => removeCartItem(item.id)}>
                                Remove
                              </button>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  )}
                </div>
              )}

              {step === 2 && (
                <div>
                  <h2 style={styles.h2}>Customize each hot dog</h2>
                  <p style={styles.helper}>Choose extras for each one — so we know exactly which hot dog gets what.</p>
                  {cartItems.every((item) => !isHotDog(item.productId)) && (
                    <p style={styles.helper}>No hot dogs in your order — drinks don't need extras, just hit Next.</p>
                  )}
                  {cartItems.map((item, idx) => {
                    const product = findProduct(item.productId);
                    if (!isHotDog(item.productId)) return null;
                    return (
                      <div key={item.id} style={styles.itemExtrasCard}>
                        <div style={styles.itemExtrasTitle}>{idx + 1}. {product.name}</div>
                        <div style={styles.toppingList}>
                          {TOPPINGS.map((t) => {
                            const q = item.toppings[t.id] || 0;
                            return (
                              <div
                                key={t.id}
                                style={{
                                  ...styles.toppingRow,
                                  borderColor: q > 0 ? "#FFCC00" : "#EAE0CB",
                                  background: q > 0 ? "#FFF7D6" : "#FFFFFF",
                                }}
                              >
                                <span style={styles.toppingName}>{t.name}</span>
                                <span style={styles.toppingPrice}>{t.price === 0 ? "Free" : `+${money(t.price)}`}</span>
                                <div style={styles.toppingQtyControl}>
                                  <button
                                    style={styles.qtyBtnSmall}
                                    onClick={() => changeItemToppingQty(item.id, t.id, -1)}
                                  >
                                    −
                                  </button>
                                  <span style={styles.qtyValueSmall}>{q}</span>
                                  <button
                                    style={styles.qtyBtnSmall}
                                    onClick={() => changeItemToppingQty(item.id, t.id, 1)}
                                  >
                                    +
                                  </button>
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      </div>
                    );
                  })}
                  <div style={styles.notesSection}>
                    <label style={styles.notesLabel}>
                      Allergies, dislikes, or anything else we should know?
                    </label>
                    <textarea
                      value={notes}
                      onChange={(e) => setNotes(e.target.value)}
                      placeholder="e.g. allergic to nuts, keep it low spice…"
                      style={styles.textarea}
                      rows={3}
                    />
                  </div>
                </div>
              )}

              {step === 3 && (
                <div>
                  <h2 style={styles.h2}>Review your order</h2>
                  <input
                    placeholder="Your name"
                    value={customerName}
                    onChange={(e) => setCustomerName(e.target.value)}
                    style={styles.input}
                  />
                  <input
                    type="email"
                    placeholder="Email"
                    value={customerEmail}
                    onChange={(e) => setCustomerEmail(e.target.value)}
                    style={styles.input}
                  />
                  <input
                    type="tel"
                    placeholder="Phone number"
                    value={customerPhone}
                    onChange={(e) => setCustomerPhone(e.target.value)}
                    style={styles.input}
                  />
                  <div style={styles.reviewBox}>
                    <div style={styles.reviewLine}>
                      <strong>{slot.dayName}</strong> · {slot.location} · {slot.time}
                    </div>
                    <div style={styles.divider} />
                    {cartItems.map((item, idx) => {
                      const product = findProduct(item.productId);
                      const itemTops = TOPPINGS.filter((t) => item.toppings[t.id]);
                      const lineTotal = product.price + itemToppingsTotal(item);
                      return (
                        <div key={item.id} style={{ marginBottom: 8 }}>
                          <div style={styles.reviewLine}>
                            {idx + 1}. {product.name} <span style={{ float: "right" }}>{money(lineTotal)}</span>
                          </div>
                          {itemTops.length > 0 && (
                            <div style={{ ...styles.reviewLine, color: "#8A6D00", paddingLeft: 12, fontSize: 13 }}>
                              + {itemTops.map((t) => (item.toppings[t.id] > 1 ? `${item.toppings[t.id]}x ${t.name}` : t.name)).join(", ")}
                            </div>
                          )}
                        </div>
                      );
                    })}
                    {notes.trim() && (
                      <div style={{ ...styles.reviewLine, color: "#FF3131" }}>
                        Note: {notes.trim()}
                      </div>
                    )}
                    <div style={styles.divider} />
                    <div style={{ ...styles.reviewLine, fontWeight: 700 }}>
                      Total <span style={{ float: "right" }}>{money(total)}</span>
                    </div>
                  </div>
                  <div style={styles.payNote}>
                    Pay by card at pickup confirmation, then send your receipt on WhatsApp — that's how we confirm your order.
                  </div>
                  {error && <div style={styles.errorText}>{error}</div>}
                </div>
              )}
            </div>

            {/* Sticky ticket footer */}
            <div style={styles.ticketFooter}>
              <div style={styles.perforation} />
              <div style={styles.ticketRow}>
                <div>
                  <div style={styles.ticketTotalLabel}>{itemCount} item{itemCount !== 1 ? "s" : ""}</div>
                  <div style={styles.ticketTotal}>{money(total)}</div>
                </div>
                <div style={{ display: "flex", gap: 8 }}>
                  {step > 0 && (
                    <button style={styles.backBtn} onClick={() => setStep((s) => s - 1)}>
                      Back
                    </button>
                  )}
                  {step < 3 ? (
                    <button
                      disabled={!canProceed}
                      style={{ ...styles.nextBtn, opacity: canProceed ? 1 : 0.4 }}
                      onClick={() => setStep((s) => s + 1)}
                    >
                      Next
                    </button>
                  ) : (
                    <button
                      disabled={!canProceed || submitting}
                      style={{ ...styles.nextBtn, opacity: canProceed && !submitting ? 1 : 0.4 }}
                      onClick={submitOrder}
                    >
                      {submitting ? "Saving…" : "Place order"}
                    </button>
                  )}
                </div>
              </div>
            </div>
          </>
        ) : (
          <div style={styles.confirmScreen}>
            <div style={styles.confirmStamp}>ORDER RECEIVED</div>
            <h2 style={styles.h2}>Thanks, {customerName.split(" ")[0]}!</h2>
            <p style={styles.helper}>
              Your order is on hold for <strong>{slot.dayName}</strong> at <strong>{slot.location}</strong> ({slot.time}).
              Order ref: <code>{orderId.slice(0, 8)}</code>
            </p>
            {saveIssue && (
              <div style={styles.saveWarning}>
                Your order is confirmed, but we had trouble syncing it to our system automatically —
                please still send your receipt on WhatsApp so we can add it manually.
              </div>
            )}
            <div style={styles.reviewBox}>
              <div style={{ ...styles.reviewLine, fontWeight: 700 }}>
                Total due {money(total)}
              </div>
            </div>
            <p style={styles.payNote}>
              1. Pay by card.<br />
              2. Send your receipt screenshot to us on WhatsApp to confirm.
            </p>
            {waLink ? (
              <a href={waLink} target="_blank" rel="noopener noreferrer" style={styles.waBtn}>
                Send receipt on WhatsApp
              </a>
            ) : (
              <div style={styles.waPending}>
                WhatsApp number coming soon — we'll share it here once it's set up.
              </div>
            )}
            <button style={styles.newOrderBtn} onClick={resetOrder}>
              Start a new order
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

